    "# Training model on 500 poster subset, hand-labeled posters using Roboflow tool.\n",
    "# Ensure to set the correct directory.\n",
    "\n",
    "from ultralytics import YOLO\n",
    "\n",
    "model = YOLO(\"yolov8s.pt\")\n",
    "results = model.train(\n",
    "    data=\"data.yaml\",\n",
    "    epochs=25,\n",
    "    imgsz=750,\n",
    "    plots=True\n",
    ")"
   ]
